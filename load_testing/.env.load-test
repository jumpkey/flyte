# .env.load-test — environment overrides for load testing against the Stripe simulator.
# Copy to .env (or export these vars) before starting the app.
#
# These settings wire the Flyte app to the local Stripe simulator so that no
# real Stripe credentials are required during load testing.

# ── Stripe simulator redirect ─────────────────────────────────────────────────
STRIPE_SIMULATOR_HOST=localhost
STRIPE_SIMULATOR_PORT=12111
STRIPE_SIMULATOR_PROTOCOL=http

# Dummy Stripe credentials (accepted by stripe-factory.ts; real Stripe is bypassed)
STRIPE_SECRET_KEY=sk_test_loadtest_simulator
STRIPE_PUBLISHABLE_KEY=pk_test_loadtest_simulator
STRIPE_WEBHOOK_SECRET=whsec_loadtest_simulator

# ── App settings (adjust to match your load-test deployment) ──────────────────
DATABASE_URL=postgres://flyte:flyte@localhost:5432/flyte
SESSION_SECRET=load-test-secret-not-for-production
APP_DOMAIN=http://localhost:3000
NODE_ENV=development

# ── Stress test settings ──────────────────────────────────────────────────────
FLYTE_URL=http://localhost:3000
# FLYTE_EVENT_ID=          ← fill in after creating the test event (see README.md)
STRIPE_SIMULATOR_URL=http://localhost:12111
